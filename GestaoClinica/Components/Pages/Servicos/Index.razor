@page "/servicos"
@using GestaoClinica.Entities
@using GestaoClinica.Services.Interfaces
@inject IServicoService ServicoService


@code {
    private IEnumerable<Servico> servicos;

    [Inject] public ISnackbar Snackbar { get; set; }
    [Inject] public NavigationManager NavigationManager { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await CarregarServicos();
    }

    private async Task CarregarServicos()
    {
        try
        {
            servicos = await ServicoService.ListarServicoAsync();
        } catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar servicos");
        }
    }
}
